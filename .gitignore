# ==========================================
# FayHub 项目 Git 忽略规则
# ==========================================

# 【IDE和开发工具配置】绝对禁止上传
.trae/
.vscode/
.idea/
*.swp
*.swo

# 【核心排除】临时文件和开发文档
临时.md
平台.md
检查.md
INSTALLATION-GUIDE.md
fayhub-dev.ps1
deploy.ps1
deploy.sh
docker-compose.yml

# 【后端】Go 编译产物和配置文件
backend/*.exe
backend/fayhub.exe
backend/fayhub-test
backend/main.exe
backend/config.yaml
backend/config.yaml.production
backend/.env.*
backend/logs/
backend/uploads/

# 【前端】Node.js 依赖和构建产物
web/node_modules/
web/dist/
web/package-lock.json

# 【文档目录】不提交到GitHub
docs/
backend/docs/

# 【开发文档和脚本】不提交到GitHub
backend/*.md
backend/*.bat
backend/*.ps1

# 【旧目录】需要清理的旧文件
frontend/
FayHub/

# 【系统文件】
.DS_Store
Thumbs.db

# 【日志文件】
*.log
logs/

# 【数据库文件】
*.db
*.sqlite
*.sqlite3

# 【备份文件】
backups/
*.bak
*.backup