# FayHub 统一环境变量配置
# 版本: 4.0 - 生产级标准化配置
# 核心原则: 所有域名访问不带端口号！通过 Nginx 反向代理实现

# ==================== 环境标识 ====================
NODE_ENV=development
FAYHUB_ENV=dev

# ==================== 域名配置（无端口） ====================
# ⚠️ 重要：这些是对外访问地址，绝对不能带端口号！
VITE_ADMIN_DOMAIN=https://admin.fayhub.com
VITE_API_DOMAIN=https://api.fayhub.com
VITE_WWW_DOMAIN=https://www.fayhub.com
VITE_DEV_DOMAIN=https://dev.fayhub.com
VITE_SSO_DOMAIN=https://sso.fayhub.com

# ==================== 内部服务端口（仅 Nginx 代理使用） ====================
# 这些端口只在服务器内部使用，用户永远看不到
VITE_ADMIN_INTERNAL_PORT=3000
VITE_API_INTERNAL_PORT=8080
VITE_SSO_INTERNAL_PORT=8080
# 注：WWW(3002) 和 DEV(3003) 已合并到 Market Next.js (3002)，无需单独端口

# ==================== API 代理配置 ====================
# Vite 开发服务器的 API 代理目标
VITE_API_PROXY_TARGET=http://localhost:8080

# ==================== 访问地址示例（正确 ✅ vs 错误 ❌） ====================
# ✅ 正确: http://admin.fayhub.com
# ✅ 正确: http://api.fayhub.com
# ❌ 错误: http://admin.fayhub.com:3000  （带了端口）
# ❌ 错误: http://api.fayhub.com:8080     （带了端口）

# ==================== 本地 Hosts 配置 ====================
# 需要添加到 C:\Windows\System32\drivers\etc\hosts:
# 127.0.0.1 admin.fayhub.com
# 127.0.0.1 api.fayhub.com
# 127.0.0.1 www.fayhub.com
# 127.0.0.1 dev.fayhub.com
# 127.0.0.1 sso.fayhub.com
