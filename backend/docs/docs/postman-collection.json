{
  "info": {
    "name": "FayHub API 测试集合",
    "description": "FayHub 多租户 SaaS 平台 API 测试集合\n\n包含用户认证、租户管理、用户管理等核心功能的完整测试用例。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "tenantId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "用户认证",
      "item": [
        {
          "name": "用户登录",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证登录成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证响应结构",
                  "pm.test(\"响应包含token\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "    pm.expect(jsonData.data.token).to.not.be.empty;",
                  "    pm.expect(jsonData.data.user).to.not.be.empty;",
                  "});",
                  "",
                  "// 保存token到环境变量",
                  "var jsonData = pm.response.json();",
                  "pm.environment.set(\"authToken\", jsonData.data.token);",
                  "pm.environment.set(\"tenantId\", jsonData.data.user.tenant_id);",
                  "pm.environment.set(\"userId\", jsonData.data.user.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "获取当前用户信息",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/user/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "me"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证获取用户信息成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证用户信息",
                  "pm.test(\"响应包含用户信息\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "    pm.expect(jsonData.data.username).to.eql(\"admin\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "租户管理",
      "item": [
        {
          "name": "获取租户列表",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tenants?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tenants"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证获取租户列表成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证响应结构",
                  "pm.test(\"响应包含租户列表\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "    pm.expect(jsonData.data.list).to.be.an('array');",
                  "    pm.expect(jsonData.data.total).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "创建租户",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"测试租户\",\n  \"domain\": \"test-tenant.fayhub.com\",\n  \"description\": \"用于测试的租户\",\n  \"status\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/tenant",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tenant"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证创建租户成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证响应结构",
                  "pm.test(\"响应包含租户信息\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "    pm.expect(jsonData.data.name).to.eql(\"测试租户\");",
                  "    pm.expect(jsonData.data.id).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "用户管理",
      "item": [
        {
          "name": "获取用户列表",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users?page=1&pageSize=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证获取用户列表成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证响应结构",
                  "pm.test(\"响应包含用户列表\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "    pm.expect(jsonData.data.list).to.be.an('array');",
                  "    pm.expect(jsonData.data.total).to.be.a('number');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "创建用户",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"test123456\",\n  \"email\": \"testuser@fayhub.com\",\n  \"phone\": \"13800138002\",\n  \"realName\": \"测试用户\",\n  \"role\": \"user\",\n  \"status\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证创建用户成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证响应结构",
                  "pm.test(\"响应包含用户信息\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "    pm.expect(jsonData.data.username).to.eql(\"testuser\");",
                  "    pm.expect(jsonData.data.id).to.not.be.empty;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "更新用户状态",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": {{userId}},\n  \"status\": 0\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user", "status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证更新用户状态成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证响应结构",
                  "pm.test(\"响应包含成功信息\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.code).to.eql(200);",
                  "    pm.expect(jsonData.message).to.eql(\"操作成功\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "多租户隔离测试",
      "item": [
        {
          "name": "测试租户隔离 - 创建不同租户用户",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"tenant1_user\",\n  \"password\": \"password123\",\n  \"email\": \"tenant1@test.com\",\n  \"realName\": \"租户1用户\",\n  \"role\": \"user\",\n  \"status\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/user",
              "host": ["{{baseUrl}}"],
              "path": ["api", "user"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证创建用户成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证用户属于当前租户",
                  "pm.test(\"用户租户ID匹配\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.tenant_id).to.eql(pm.environment.get(\"tenantId\"));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "测试租户隔离 - 查询用户列表",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 验证查询成功",
                  "pm.test(\"状态码应为200\", function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// 验证只返回当前租户用户",
                  "pm.test(\"用户列表租户隔离验证\", function() {",
                  "    var jsonData = pm.response.json();",
                  "    var users = jsonData.data.list;",
                  "    var currentTenantId = pm.environment.get(\"tenantId\");",
                  "    ",
                  "    users.forEach(function(user) {",
                  "        pm.expect(user.tenant_id).to.eql(currentTenantId);",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}