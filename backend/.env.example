# FayHub 后端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 数据库配置
FAYHUB_DB_HOST=localhost
FAYHUB_DB_PORT=5432
FAYHUB_DB_USERNAME=fayhub
FAYHUB_DB_PASSWORD=your_secure_database_password_here
FAYHUB_DB_NAME=fayhub

# 服务器配置
FAYHUB_SERVER_PORT=8080

# JWT配置
FAYHUB_JWT_SECRET=your_secure_jwt_secret_key_here

# Redis配置（可选）
FAYHUB_REDIS_HOST=localhost
FAYHUB_REDIS_PORT=6379
FAYHUB_REDIS_PASSWORD=
FAYHUB_REDIS_DB=0