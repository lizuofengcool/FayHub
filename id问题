## 二、菜单处理的三种方案对比与实现

| 方案 | 适用场景 | 优点 | 缺点 | 推荐指数 |
|------|----------|------|------|----------|
| **卸载删除** | 彻底移除插件，不再使用 | 数据清洁，无冗余 | 不可恢复，误删风险 | ⭐⭐⭐⭐ |
| **停用隐藏** | 临时禁用插件，可能复用 | 操作可逆，安全 | 数据冗余，查询效率低 | ⭐⭐⭐ |
| **双轨策略** | 生产环境，支持完整生命周期 | 兼顾清洁与可逆 | 实现略复杂 | ⭐⭐⭐⭐⭐ |

### 1. 双轨策略实现（推荐）
```typescript
// FayHub插件系统核心代码 - 菜单管理模块
// 1. 插件状态枚举
export enum PluginStatus {
  ACTIVE = 'active',    // 激活
  INACTIVE = 'inactive',// 停用（隐藏菜单）
  UNINSTALLED = 'uninstalled'// 卸载（删除菜单）
}

// 2. 插件卸载核心逻辑
async function uninstallPlugin(pluginId: string) {
  // 步骤1：事务开始（Prisma确保原子性）
  const tx = await prisma.$transaction(async (prisma) => {
    // 步骤2：删除插件所有菜单（物理删除）
    await prisma.menuItem.deleteMany({
      where: { pluginId }
    });
    
    // 步骤3：标记插件为已卸载状态
    await prisma.plugin.update({
      where: { id: pluginId },
      data: { status: PluginStatus.UNINSTALLED }
    });
    
    // 步骤4：清除插件缓存和资源
    pluginEngine.unload(pluginId);
    cache.invalidate(`plugin:${pluginId}`);
  });
  
  return tx;
}

// 3. 插件停用核心逻辑（隐藏菜单）
async function deactivatePlugin(pluginId: string) {
  await prisma.plugin.update({
    where: { id: pluginId },
    data: { status: PluginStatus.INACTIVE }
  });
  
  // 前端自动过滤状态为inactive的插件菜单
  // 无需修改数据库菜单记录，仅更新状态标记
}
```

