## 五、关键代码实现示例

### 1. 完整的插件生命周期管理
```typescript
// plugin.service.ts - 插件核心服务
export class PluginService {
  private idManager = new BusinessIdManager(this.prisma);
  
  constructor(private prisma: PrismaClient) {}
  
  // 安装插件（包含菜单创建）
  async installPlugin(pluginData: PluginCreateInput) {
    const businessId = await this.idManager.getNextId();
    
    return this.prisma.$transaction(async (tx) => {
      // 创建插件记录
      const plugin = await tx.plugin.create({
        data: {
          ...pluginData,
          businessId,
          status: PluginStatus.ACTIVE
        }
      });
      
      // 创建插件菜单
      if (pluginData.menus) {
        await tx.menuItem.createMany({
          data: pluginData.menus.map(menu => ({
            ...menu,
            pluginId: plugin.id
          }))
        });
      }
      
      return plugin;
    });
  }
  
  // 卸载插件（删除菜单）
  async uninstallPlugin(pluginId: string) {
    return this.prisma.$transaction(async (tx) => {
      const plugin = await tx.plugin.findUniqueOrThrow({
        where: { id: pluginId },
        include: { menus: true }
      });
      
      // 删除所有菜单
      await tx.menuItem.deleteMany({
        where: { pluginId }
      });
      
      // 标记为已卸载，保留businessId用于回收
      await tx.plugin.update({
        where: { id: pluginId },
        data: { status: PluginStatus.UNINSTALLED }
      });
      
      // 通知ID管理器回收该businessId
      this.idManager.recycleId(plugin.businessId);
      
      return plugin;
    });
  }
}
```

### 2. BusinessIdManager实现
```typescript
// business-id-manager.ts - 业务ID管理服务
export class BusinessIdManager {
  private recycledIds: number[] = [];
  private currentMaxId = 0;
  
  constructor(private prisma: PrismaClient) {
    this.init();
  }
  
  // 初始化：加载已回收的ID和当前最大ID
  private async init() {
    // 加载已卸载插件的businessId（可回收）
    const uninstalledPlugins = await this.prisma.plugin.findMany({
      where: { status: PluginStatus.UNINSTALLED },
      select: { businessId: true }
    });
    this.recycledIds = uninstalledPlugins.map(p => p.businessId).sort((a, b) => a - b);
    
    // 加载当前最大活跃ID
    const maxActiveId = await this.prisma.plugin.aggregate({
      _max: { businessId: true },
      where: { status: { not: PluginStatus.UNINSTALLED } }
    });
    this.currentMaxId = maxActiveId._max.businessId || 0;
  }
  
  // 获取下一个可用ID（优先复用）
  async getNextId(): Promise<number> {
    if (this.recycledIds.length > 0) {
      return this.recycledIds.shift()!;
    }
    
    this.currentMaxId += 1;
    return this.currentMaxId;
  }
  
  // 回收ID
  recycleId(id: number) {
    if (id > this.currentMaxId) return;
    
    // 插入到正确位置，保持数组有序
    const index = this.recycledIds.findIndex(rid => rid > id);
    if (index === -1) {
      this.recycledIds.push(id);
    } else {
      this.recycledIds.splice(index, 0, id);
    }
  }
}
```

